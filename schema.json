{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["basics"],
  "properties": {
    "basics": {
      "type": "object",
      "required": ["name", "label", "summary"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Seu nome",
          "minLength": 2
        },
        "label": {
          "type": "string",
          "description": "Seu título profissional (ex: Desenvolvedor Full Stack)",
          "minLength": 2
        },
        "image": {
          "type": "string",
          "description": "URL da sua foto de perfil. Use https://github.com/seu-usuario.png e será detectado automaticamente baseado no seu username do GitHub!",
          "format": "uri"
        },
        "email": {
          "type": "string",
          "description": "Seu email de contato",
          "format": "email"
        },
        "heroGifUrl": {
          "type": "string",
          "description": "URL de um GIF de destaque para o painel lateral",
          "format": "uri"
        },
        "summary": {
          "type": "string",
          "description": "Uma breve descrição sobre você (2-3 frases)",
          "minLength": 10
        },
        "location": {
          "type": "object",
          "properties": {
            "city": {
              "type": "string",
              "description": "Cidade"
            },
            "region": {
              "type": "string",
              "description": "Estado (ex: SP)"
            }
          }
        },
        "profiles": {
          "type": "array",
          "description": "Suas redes sociais",
          "items": {
            "type": "object",
            "required": ["network", "url"],
            "properties": {
              "network": {
                "type": "string",
                "description": "Nome da rede social",
                "enum": [
                  "GitHub",
                  "LinkedIn",
                  "Twitter",
                  "Instagram",
                  "Facebook",
                  "YouTube",
                  "TikTok"
                ]
              },
              "username": {
                "type": "string",
                "description": "Seu usuário nesta rede"
              },
              "url": {
                "type": "string",
                "description": "Link do seu perfil",
                "format": "uri"
              }
            }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "description": "Suas habilidades técnicas",
      "items": {
        "type": "string",
        "description": "Nome da habilidade/tecnologia"
      }
    },
    "projects": {
      "type": "array",
      "description": "Seus projetos principais",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nome do projeto"
          },
          "url": {
            "type": "string",
            "description": "Link do projeto (GitHub, demo, etc)",
            "format": "uri"
          }
        }
      }
    },
    "education": {
      "type": "array",
      "description": "Sua formação acadêmica",
      "items": {
        "type": "object",
        "required": ["institution", "area", "studyType", "startDate"],
        "properties": {
          "institution": {
            "type": "string",
            "description": "Nome da instituição de ensino"
          },
          "area": {
            "type": "string",
            "description": "Área de estudo/curso"
          },
          "studyType": {
            "type": "string",
            "description": "Tipo (Bacharelado, Tecnólogo, Bootcamp, etc)"
          },
          "startDate": {
            "type": "string",
            "description": "Data de início (YYYY-MM)",
            "pattern": "^[0-9]{4}-[0-9]{2}$"
          },
          "endDate": {
            "type": "string",
            "description": "Data de conclusão (YYYY-MM) ou vazio se em andamento",
            "pattern": "^([0-9]{4}-[0-9]{2})?$"
          }
        }
      }
    },
    "work": {
      "type": "array",
      "description": "Sua experiência profissional",
      "items": {
        "type": "object",
        "required": ["name", "position", "startDate"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nome da empresa"
          },
          "position": {
            "type": "string",
            "description": "Seu cargo"
          },
          "startDate": {
            "type": "string",
            "description": "Data de início (YYYY-MM)",
            "pattern": "^[0-9]{4}-[0-9]{2}$"
          },
          "endDate": {
            "type": "string",
            "description": "Data de saída (YYYY-MM) ou vazio se atual",
            "pattern": "^([0-9]{4}-[0-9]{2})?$"
          }
        }
      }
    },
    "config": {
      "type": "object",
      "description": "Configurações de personalização do portfolio",
      "properties": {
        "theme": {
          "type": "string",
          "description": "Tema visual",
          "default": "default"
        },
        "accentColor": {
          "type": "string",
          "description": "Cor de destaque (hex)",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "default": "#6366f1"
        },
        "starterPokemon": {
          "type": "string",
          "description": "Pokemon inicial que define a paleta visual pixel art",
          "enum": ["squirtle", "bulbasaur", "charmander"],
          "default": "squirtle"
        },
        "showFooterCredit": {
          "type": "boolean",
          "description": "Mostrar 'Feito com Pokefolio' no rodapé",
          "default": true
        }
      }
    }
  }
}
