{
  "name": "pokefolio",
  "version": "1.0.0",
  "description": "Crie seu portfólio profissional editando um JSON. Deploy automático via GitHub Pages.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate && next build",
    "start": "next start",
    "lint": "next lint",
    "validate": "tsx scripts/validate-data.ts",
    "fetch:github": "tsx scripts/fetch-github-data.ts",
    "update:config": "tsx scripts/update-repo-config.ts",
    "prebuild": "npm run update:config"
  },
  "dependencies": {
    "@hackernoon/pixel-icon-library": "^1.0.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "nes.css": "^2.2.1",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
